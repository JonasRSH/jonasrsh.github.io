# Production Environment Variables Template
# Kopiere diese Datei zu .env.prod und fülle die echten Werte ein:
# cp .env.prod.example .env.prod

# Django Secret Key - Generiere mit:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Email-Konfiguration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Debug-Modus (MUSS False sein in Production)
DEBUG=False

# Datenbank für Production
DATABASE_URL=postgresql://user:password@db:5432/dbname

# Production-Einstellungen
DJANGO_ENV=production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Sicherheits-Einstellungen für Production
SECURE_SSL_REDIRECT=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Logging Level
LOG_LEVEL=WARNING
